{
  "name": "mcp-server-framework",
  "version": "1.0.0",
  "description": "Production-ready MCP Server Framework with built-in logging, metrics, sessions, and multi-transport support.",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build node_modules",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "keywords": [
    "framework",
    "mcp-server",
    "mcp",
    "model-context-protocol",
    "ts",
    "typescript"
  ],
  "license": "GPL-3.0",
  "author": "Marcel Pfennig",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MP-Tool/mcp-server-framework.git"
  },
  "bugs": {
    "url": "https://github.com/MP-Tool/mcp-server-framework/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "build/**/*.js",
    "build/**/*.d.ts",
    "build/VERSION",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "zod": "^3.23.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/resources": "^2.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "typescript": "^5.0.0"
  }
}
