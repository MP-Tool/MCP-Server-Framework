{
  "name": "mcp-server-framework",
  "version": "1.0.5",
  "description": "Production-ready MCP Server Framework with built-in logging, metrics, sessions, and multi-transport support.",
  "license": "LGPL-3.0",
  "author": "Marcel Pfennig",
  "homepage": "https://github.com/MP-Tool/mcp-server-framework#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MP-Tool/mcp-server-framework.git"
  },
  "bugs": {
    "url": "https://github.com/MP-Tool/mcp-server-framework/issues"
  },
  "keywords": [
    "typescript",
    "model-context-protocol",
    "mcp",
    "mcp-server",
    "framework"
  ],
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    },
    "./config": {
      "types": "./build/config/index.d.ts",
      "import": "./build/config/index.js"
    },
    "./errors": {
      "types": "./build/errors/index.d.ts",
      "import": "./build/errors/index.js"
    },
    "./http": {
      "types": "./build/server/http/index.d.ts",
      "import": "./build/server/http/index.js"
    },
    "./logger": {
      "types": "./build/logger/index.d.ts",
      "import": "./build/logger/index.js"
    },
    "./session": {
      "types": "./build/server/session/index.d.ts",
      "import": "./build/server/session/index.js"
    },
    "./telemetry": {
      "types": "./build/telemetry/index.d.ts",
      "import": "./build/telemetry/index.js"
    }
  },
  "sideEffects": [
    "./build/mcp/capabilities/registry/tool-registry.js",
    "./build/mcp/capabilities/registry/resource-registry.js",
    "./build/mcp/capabilities/registry/prompt-registry.js",
    "./build/mcp/capabilities/registry/task-tool-registry.js"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "build/**/*.js",
    "build/**/*.js.map",
    "build/**/*.d.ts",
    "build/**/*.d.ts.map",
    "README.md",
    "LICENSE.txt",
    "LICENSE-GPL.txt",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\" \"*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "typedoc",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-prometheus": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation-express": "^0.61.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "smol-toml": "^1.3.1",
    "yaml": "^2.7.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "prettier": "^3.7.4",
    "typedoc": "^0.28.17",
    "typedoc-plugin-mermaid": "^1.12.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
